{% extends 'base.html.twig' %}

{% block title %}{{ 'search.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        .relation-graph-container {
            width: 100%;
            height: 400px;
            overflow: auto;
            background: #f8f9fa;
            border-radius: 8px;
            padding: 20px;
        }
        .mermaid {
            display: flex;
            justify-content: center;
        }
        .type-dropdown-list .custom-checkbox:last-child {
            margin-bottom: 0 !important;
        }
        .type-dropdown-list::-webkit-scrollbar {
            width: 4px;
        }
        .type-dropdown-list::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 4px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-md-12 mb-4">
            <h1 class="display-4"><i class="fa fa-search mr-3"></i>{{ 'search.title'|trans }}</h1>
            <p class="lead">Search across ocean data collections and information systems.</p>
        </div>

        <div class="col-md-10">
            <form action="{{ path('app_search') }}" method="get" class="mb-5 shadow-sm">
                <div class="input-group input-group-lg">
                    <input type="text" name="q" class="form-control" placeholder="{{ 'search.input_placeholder'|trans }}" value="{{ query }}">
                    <input type="hidden" name="sort" value="{{ currentSort }}">
                    <input type="hidden" name="order" value="{{ currentOrder }}">
                    {% if facets.types is not defined or facets.types|length == 0 %}
                        {% for type in currentTypes %}
                            <input type="hidden" name="types[]" value="{{ type }}">
                        {% endfor %}
                    {% endif %}
                    <input type="hidden" name="limit" value="{{ currentLimit }}">
                    <div class="input-group-append">
                        {% if query is not empty or currentTypes is not empty %}
                            <a href="{{ path('app_search') }}" class="btn btn-outline-secondary d-flex align-items-center px-3 border-right-0 rounded-0" title="{{ 'search.clear'|trans }}">
                                <i class="fa fa-times mr-1"></i>{{ 'search.clear'|trans }}
                            </a>
                        {% endif %}
                        {% if facets.types is defined and facets.types|length > 0 %}
                            {% set shownTypeKeys = [] %}
                            {% for bucket in facets.types %}
                                {% set shownTypeKeys = shownTypeKeys|merge([bucket.key]) %}
                            {% endfor %}
                            
                            {# Keep hidden inputs for types that are NOT in the facet list (e.g. manually added or from a previous result set) #}
                            {% for type in currentTypes %}
                                {% if type not in shownTypeKeys %}
                                    <input type="hidden" name="types[]" value="{{ type }}">
                                {% endif %}
                            {% endfor %}
                            
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle h-100 rounded-0 border-left-0" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <i class="fa fa-filter mr-1"></i>{{ 'search.types'|trans }}
                                </button>
                                <div class="dropdown-menu dropdown-menu-right p-3 shadow" style="min-width: 300px;">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="dropdown-header px-0 mb-0 border-0 text-dark font-weight-bold">{{ 'search.filter_by_type'|trans }}</h6>
                                        <button type="submit" class="btn btn-primary btn-sm px-3 shadow-sm">{{ 'search.apply_filters'|trans }}</button>
                                    </div>
                                    <div class="dropdown-divider mt-1 mb-3"></div>
                                    <div class="type-dropdown-list px-1" style="max-height: 350px; overflow-y: auto;">
                                        {% for bucket in facets.types %}
                                            {% set isChecked = bucket.key in currentTypes %}
                                            <div class="custom-control custom-checkbox mb-3">
                                                <input type="checkbox" name="types[]" value="{{ bucket.key }}" class="custom-control-input" id="type-dropdown-{{ loop.index }}" {{ isChecked ? 'checked' }}>
                                                <label class="custom-control-label small d-flex justify-content-between align-items-center w-100 cursor-pointer" for="type-dropdown-{{ loop.index }}">
                                                    <span class="text-truncate pr-2" style="max-width: 180px;">
                                                        {% set typeKey = bucket.key is iterable ? bucket.key|join(', ') : bucket.key %}
                                                        {% set typeCleaned = typeKey|replace({'{value=': '', '}': '', 'http://schema.org/': '', 'https://schema.org/': '', 'schema:': ''}) %}
                                                        {{ typeCleaned }}
                                                    </span>
                                                    <span class="badge badge-pill badge-light border text-muted">{{ bucket.doc_count }}</span>
                                                </label>
                                            </div>
                                        {% endfor %}
                                    </div>
                                    <div class="dropdown-divider mb-2"></div>
                                    <a href="{{ path('app_search', {q: query}) }}" class="btn btn-link btn-sm text-danger btn-block text-decoration-none">
                                        <i class="fa fa-times-circle mr-1"></i> {{ 'search.clear_types'|trans }}
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                        <button class="btn btn-primary px-4" type="submit">{{ 'nav.search'|trans }}</button>
                    </div>
                </div>
            </form>

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}

            {% if query is not empty or results|length > 0 %}
                <div class="row mb-3">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded shadow-sm">
                            <span class="text-muted small">
                                {% if query is not empty %}
                                    {{ 'search.found_results'|trans({'%count%': totalResults|default(results|length), '%query%': query})|raw }}
                                {% else %}
                                    {{ 'search.found_records'|trans({'%count%': totalResults}) }}
                                {% endif %}
                            </span>
                            <div class="d-flex align-items-center">
                                <div class="dropdown mr-2">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-toggle="dropdown">
                                        {{ 'search.per_page'|trans }}: {{ currentLimit }}
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right">
                                        {% if query is not empty %}
                                            <a class="dropdown-item" href="{{ path('app_search', {q: query, types: currentTypes, sort: currentSort, order: currentOrder, limit: 5}) }}">5</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {q: query, types: currentTypes, sort: currentSort, order: currentOrder, limit: 10}) }}">10</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {q: query, types: currentTypes, sort: currentSort, order: currentOrder, limit: 20}) }}">20</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {q: query, types: currentTypes, sort: currentSort, order: currentOrder, limit: 50}) }}">50</a>
                                        {% else %}
                                            <a class="dropdown-item" href="{{ path('app_search', {types: currentTypes, sort: currentSort, order: currentOrder, limit: 5}) }}">5</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {types: currentTypes, sort: currentSort, order: currentOrder, limit: 10}) }}">10</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {types: currentTypes, sort: currentSort, order: currentOrder, limit: 20}) }}">20</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {types: currentTypes, sort: currentSort, order: currentOrder, limit: 50}) }}">50</a>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-toggle="dropdown">
                                        {{ 'search.sort_by'|trans }}: {{ currentSort == 'name' ? 'Name'|trans : 'Relevance'|trans }} 
                                        ({{ currentOrder == 'asc' ? 'Asc'|trans : 'Desc'|trans }})
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right">
                                        {% if query is not empty %}
                                            <a class="dropdown-item" href="{{ path('app_search', {q: query, types: currentTypes, sort: '_score', order: 'desc', limit: currentLimit}) }}">Relevance</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {q: query, types: currentTypes, sort: 'name', order: 'asc', limit: currentLimit}) }}">Name (A-Z)</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {q: query, types: currentTypes, sort: 'name', order: 'desc', limit: currentLimit}) }}">Name (Z-A)</a>
                                        {% else %}
                                            <a class="dropdown-item" href="{{ path('app_search', {types: currentTypes, sort: 'name', order: 'asc', limit: currentLimit}) }}">Name (A-Z)</a>
                                            <a class="dropdown-item" href="{{ path('app_search', {types: currentTypes, sort: 'name', order: 'desc', limit: currentLimit}) }}">Name (Z-A)</a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light font-weight-bold">{{ 'search.filter_by_type'|trans }}</div>
                            <form action="{{ path('app_search') }}" method="get">
                                <input type="hidden" name="q" value="{{ query }}">
                                <input type="hidden" name="sort" value="{{ currentSort }}">
                                <input type="hidden" name="order" value="{{ currentOrder }}">
                                <input type="hidden" name="limit" value="{{ currentLimit }}">
                                    <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                                        {% if query is not empty %}
                                            <a href="{{ path('app_search', {q: query, sort: currentSort, order: currentOrder, limit: currentLimit}) }}" 
                                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center {{ (currentTypes is empty) ? 'active' }}">
                                                <span>{{ 'search.all_types'|trans }}</span>
                                                <i class="fa fa-layer-group"></i>
                                            </a>
                                        {% else %}
                                            <a href="{{ path('app_search', {sort: currentSort, order: currentOrder, limit: currentLimit}) }}" 
                                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center {{ (currentTypes is empty) ? 'active' }}">
                                                <span>{{ 'search.all_types'|trans }}</span>
                                                <i class="fa fa-layer-group"></i>
                                            </a>
                                        {% endif %}
                                        {% if facets.types is defined %}
                                            {% for bucket in facets.types %}
                                                {% set isChecked = bucket.key in currentTypes %}
                                                <div class="list-group-item d-flex justify-content-between align-items-center {{ isChecked ? 'bg-light font-weight-bold' }}">
                                                    <div class="custom-control custom-checkbox w-100">
                                                        <input type="checkbox" name="types[]" value="{{ bucket.key }}" class="custom-control-input" id="type-{{ loop.index }}" {{ isChecked ? 'checked' }}>
                                                        <label class="custom-control-label small d-flex justify-content-between align-items-center w-100 cursor-pointer" for="type-{{ loop.index }}">
                                                            <span class="text-truncate mr-2" title="{{ bucket.key is iterable ? bucket.key|join(', ') : bucket.key }}">
    {% set typeKey = bucket.key is iterable ? bucket.key|join(', ') : bucket.key %}
    {% set typeCleaned = typeKey|replace({'{value=': '', '}': '', 'http://schema.org/': '', 'https://schema.org/': '', 'schema:': ''}) %}
    {{ typeCleaned }}
</span>
                                                            <span class="badge badge-pill {{ isChecked ? 'badge-primary' : 'badge-secondary' }}">{{ bucket.doc_count }}</span>
                                                        </label>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        {% endif %}
                                    </div>
                                    <div class="card-footer p-3 bg-white border-top">
                                        <div class="row no-gutters">
                                            <div class="col-12 mb-2">
                                                <button type="submit" class="btn btn-primary btn-sm btn-block shadow-sm">
                                                    <i class="fa fa-sync mr-1"></i> {{ 'search.apply_filters'|trans }}
                                                </button>
                                            </div>
                                            <div class="col-12">
                                                <a href="{{ path('app_search', {q: query}) }}" class="btn btn-outline-danger btn-sm btn-block">
                                                    <i class="fa fa-trash-alt mr-1"></i> {{ 'search.clear_types'|trans }}
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                            </form>
                        </div>
                    </div>
                    <div class="col-md-9">
                        {% for hit in results %}
                            {% set source = hit._source %}
                            <div class="card mb-3 shadow-sm result-item">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h5 class="card-title">
                                            {% set rawId = attribute(source, '@id') is defined ? attribute(source, '@id') : null %}
                                            {% set firstId = (rawId is iterable ? rawId|first : rawId) %}
                                            {# If firstId is still an array/object (e.g. @value), try to convert to string #}
                                            {% set firstIdStr = firstId is iterable ? firstId|join(' ') : firstId|trim|default('') %}
                                            
                                            {% set rawUrl = source.url is defined ? source.url : null %}
                                            {% set firstUrl = (rawUrl is iterable ? rawUrl|first : rawUrl) %}
                                            {% set firstUrlStr = firstUrl is iterable ? firstUrl|join(' ') : firstUrl|trim|default('') %}

                                            {% set primaryLink = (firstIdStr|slice(0, 4) == 'http') 
                                                ? firstIdStr 
                                                : (firstUrlStr|slice(0, 4) == 'http' 
                                                    ? firstUrlStr 
                                                    : (source._crawl_url|default('#'))) 
                                            %}
                                            <a href="{{ primaryLink }}" target="_blank">
                                                {% if hit.highlight is defined and hit.highlight.name is defined %}
                                                    {{ hit.highlight.name[0]|raw }}
                                                {% else %}
                                                    {% set name = (source.name is defined or attribute(source, 'schema:name') is defined or (source.data is defined and (source.data.name is defined or attribute(source.data, 'schema:name') is defined)))
                                                        ? (source.name is defined 
                                                            ? (source.name is iterable 
                                                                ? (source.name.name is defined 
                                                                    ? source.name.name 
                                                                    : (attribute(source.name, 'schema:name') is defined 
                                                                        ? attribute(source.name, 'schema:name')
                                                                        : (source.name|first is iterable 
                                                                            ? (source.name|first).name|default(attribute(source.name|first, 'schema:name')|default(source.name|join(', '))) 
                                                                            : source.name|join(', ')))) 
                                                                : source.name) 
                                                            : (attribute(source, 'schema:name') is defined 
                                                                ? attribute(source, 'schema:name') 
                                                                : (source.data.name is defined 
                                                                    ? (source.data.name is iterable ? source.data.name|join(', ') : source.data.name)
                                                                    : (attribute(source.data, 'schema:name') is iterable ? attribute(source.data, 'schema:name')|join(', ') : attribute(source.data, 'schema:name')))))
                                                        : 'Untitled Record' %}
                                                    {{ name is iterable ? name|join(', ') : name }}
                                                {% endif %}
                                            </a>
                                            {% if primaryLink == '#' %}
                                                <div class="text-danger small mt-1">
                                                    <i class="fa fa-exclamation-triangle mr-1"></i>{{ 'search.no_link'|trans }}
                                                </div>
                                            {% endif %}
                                        </h5>
                                        <div class="d-flex align-items-center">
                                            {% if source.name is defined or attribute(source, 'schema:name') is defined %}
                                                {% set dataName = source.name is defined 
                                                    ? (source.name is iterable 
                                                        ? (source.name.name is defined 
                                                            ? source.name.name 
                                                            : (attribute(source.name, 'schema:name') is defined 
                                                                ? attribute(source.name, 'schema:name')
                                                                : (source.name|first is iterable 
                                                                    ? (source.name|first).name|default(attribute(source.name|first, 'schema:name')|default(source.name|first|join(' '))) 
                                                                    : source.name|first))) 
                                                        : source.name)
                                                    : attribute(source, 'schema:name') %}
                                                {% if dataName is iterable %}{% set dataName = dataName|join(' ') %}{% endif %}
                                                <button class="btn btn-sm btn-outline-info mr-2 show-relations-btn" 
                                                        data-name="{{ dataName|trim }}"
                                                        data-exclude-id="{{ hit._id }}"
                                                        title="{{ 'search.show_relations'|trans }}">
                                                    <i class="fa fa-sitemap"></i>
                                                </button>
                                            {% endif %}
                                            <span class="badge badge-light border text-muted small" title="Relevance Score: {{ hit._score }}">
                                                Score: {{ hit._score|round(2) }}
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <h6 class="card-subtitle mb-2 text-muted small">
                                        <i class="fa fa-link mr-1"></i>{{ primaryLink != '#' ? primaryLink : 'No URL available'|trans }}
                                        {% if attribute(source, '@type') is defined %}
    <span class="ml-2 badge badge-pill badge-light border">
        {% set typeRaw = attribute(source, '@type') %}
        {% set typeStr = typeRaw is iterable ? typeRaw|join(', ') : typeRaw %}
        {{ typeStr|replace({'{value=': '', '}': '', 'http://schema.org/': '', 'https://schema.org/': '', 'schema:': ''}) }}
    </span>
{% endif %}
                                    </h6>

                                    <div class="card-text">
                                        {% if hit.highlight is defined and hit.highlight.description is defined %}
                                            <div class="highlight-description p-1 mb-2">
                                                ...{{ hit.highlight.description[0]|raw }}...
                                            </div>
                                        {% elseif hit.highlight is defined and hit.highlight.text is defined %}
                                             <div class="highlight-text p-1 mb-2 small text-muted">
                                                ...{{ hit.highlight.text[0]|raw }}...
                                            </div>
                                        {% else %}
                                            <p class="mb-2">
                                            {% set description = (source.description is defined or attribute(source, 'schema:description') is defined or (source.data is defined and source.data.description is defined) or (source.data is defined and attribute(source.data, 'schema:description') is defined)) 
                                                ? (source.description is defined 
                                                    ? (source.description is iterable ? source.description|join(' ') : source.description)
                                                    : (attribute(source, 'schema:description') is defined 
                                                        ? (attribute(source, 'schema:description') is iterable ? attribute(source, 'schema:description')|join(' ') : attribute(source, 'schema:description'))
                                                        : (source.data.description is defined 
                                                            ? (source.data.description is iterable ? source.data.description|join(' ') : source.data.description)
                                                            : (attribute(source.data, 'schema:description') is iterable ? attribute(source.data, 'schema:description')|join(' ') : attribute(source.data, 'schema:description')))))
                                                : 'No description provided.'|trans %}
                                                {{ description|length > 300 ? description|slice(0, 300) ~ '...' : description }}
                                            </p>
                                        {% endif %}
                                    </div>
                                    
                        {% if source.keywords is defined or (hit.highlight is defined and hit.highlight.keywords is defined) %}
                                        <div class="mt-2">
                                            <i class="fa fa-tags mr-1 text-muted small"></i>
                                            {% if hit.highlight is defined and hit.highlight.keywords is defined %}
                                                {% for kw in hit.highlight.keywords %}
                                                    <span class="badge badge-info">{{ kw|raw }}</span>
                                                {% endfor %}
                                            {% elseif source.keywords is iterable %}
                                                {% for keyword in source.keywords %}
                                                    {% set kwName = (keyword.name is defined) 
                                                        ? (keyword.name is iterable ? keyword.name|join(', ') : keyword.name) 
                                                        : (attribute(keyword, 'schema:name') is defined
                                                            ? (attribute(keyword, 'schema:name') is iterable ? attribute(keyword, 'schema:name')|join(', ') : attribute(keyword, 'schema:name'))
                                                            : (keyword is iterable ? keyword|join(', ') : keyword)) %}
                                                    <span class="badge badge-info">{{ kwName|replace({'schema:': ''}) }}</span>
                                                {% endfor %}
                                            {% elseif attribute(source, 'schema:keywords') is defined %}
                                                {% set schemaKeywords = attribute(source, 'schema:keywords') %}
                                                {% if schemaKeywords is iterable %}
                                                    {% for keyword in schemaKeywords %}
                                                        {% set kwName = keyword is iterable ? (keyword.name|default(attribute(keyword, 'schema:name')|default(keyword|join(', ')))) : keyword %}
                                                        <span class="badge badge-info">{{ kwName|replace({'schema:': ''}) }}</span>
                                                    {% endfor %}
                                                {% else %}
                                                    {% for keyword in schemaKeywords|split(',') %}
                                                        <span class="badge badge-info">{{ keyword|trim|replace({'schema:': ''}) }}</span>
                                                    {% endfor %}
                                                {% endif %}
                                            {% elseif source.keywords is defined %}
                                                {% for keyword in source.keywords|split(',') %}
                                                    <span class="badge badge-info">{{ keyword|trim|replace({'schema:': ''}) }}</span>
                                                {% endfor %}
                                            {% endif %}
                                        </div>
                                    {% endif %}

                                    {% if hit.highlight is defined or source.odis_cat_id is defined %}
                                        <div class="mt-3 p-2 bg-light rounded border-left border-primary small">
                                            {% if hit.highlight is defined %}
                                                <div class="mb-1">
                                                    <strong class="text-primary"><i class="fa fa-info-circle mr-1"></i> {{ 'search.why_this_result'|trans }}</strong>
                                                    <div class="text-muted ml-1 mt-1">
                                                        {% for field, matches in hit.highlight %}
                                                            <div class="mb-2">
                                                                <code class="px-1 bg-white border rounded text-dark font-weight-bold">{{ field|replace({'schema:': '', '.name': '', '.description': ''})|capitalize }}</code>:
                                                                {% for match in matches %}
                                                                    <div class="ml-2 mt-1 font-italic bg-white p-1 border-left border-info rounded-right">
                                                                        ...{{ match|raw }}...
                                                                    </div>
                                                                {% endfor %}
                                                            </div>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            {% endif %}
                                            {% if source.odis_cat_id is defined %}
                                                <div class="mt-1">
                                                    <i class="fa fa-database mr-1 text-muted"></i> Source: 
                                                    <a href="{{ source.odis_cat_url|default('https://catalogue.odis.org/view/' ~ source.odis_cat_id) }}" target="_blank" class="text-secondary font-weight-bold">
                                                        ODIS Catalogue ID {{ source.odis_cat_id }}
                                                    </a>
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% else %}
                            <div class="alert alert-warning">No results found for your search.</div>
                        {% endfor %}

                        {% if totalPages > 1 %}
                            <nav class="mt-4">
                                <ul class="pagination justify-content-center">
                                    <li class="page-item {{ currentPage == 1 ? 'disabled' }}">
                                        {% if query is not empty %}
                                            <a class="page-item page-link" href="{{ path('app_search', {q: query, types: currentTypes, sort: currentSort, order: currentOrder, limit: currentLimit, page: currentPage - 1}) }}">Previous</a>
                                        {% else %}
                                            <a class="page-item page-link" href="{{ path('app_search', {types: currentTypes, sort: currentSort, order: currentOrder, limit: currentLimit, page: currentPage - 1}) }}">Previous</a>
                                        {% endif %}
                                    </li>
                                    
                                    {% set start = max(1, currentPage - 2) %}
                                    {% set end = min(totalPages, start + 4) %}
                                    {% if end == totalPages and totalPages > 5 %}
                                        {% set start = max(1, totalPages - 4) %}
                                    {% endif %}
                                    
                                    {% for p in start..end %}
                                        <li class="page-item {{ p == currentPage ? 'active' }}">
                                            {% if query is not empty %}
                                                <a class="page-link" href="{{ path('app_search', {q: query, types: currentTypes, sort: currentSort, order: currentOrder, limit: currentLimit, page: p}) }}">{{ p }}</a>
                                            {% else %}
                                                <a class="page-link" href="{{ path('app_search', {types: currentTypes, sort: currentSort, order: currentOrder, limit: currentLimit, page: p}) }}">{{ p }}</a>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                    
                                    <li class="page-item {{ currentPage == totalPages ? 'disabled' }}">
                                        {% if query is not empty %}
                                            <a class="page-link" href="{{ path('app_search', {q: query, types: currentTypes, sort: currentSort, order: currentOrder, limit: currentLimit, page: currentPage + 1}) }}">Next</a>
                                        {% else %}
                                            <a class="page-link" href="{{ path('app_search', {types: currentTypes, sort: currentSort, order: currentOrder, limit: currentLimit, page: currentPage + 1}) }}">Next</a>
                                        {% endif %}
                                    </li>
                                </ul>
                            </nav>
                        {% endif %}

                        {% if totalResults|default(results|length) > results|length %}
                            <div class="text-center mt-3 mb-5">
                                <p class="text-muted small">Showing {{ (currentPage - 1) * currentLimit + 1 }} to {{ min(currentPage * currentLimit, totalResults) }} of {{ totalResults }} results.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<!-- Relations Modal -->
<div class="modal fade" id="relationsModal" tabindex="-1" role="dialog" aria-labelledby="relationsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="relationsModalLabel">{{ 'search.relations_for'|trans({'%name%': '<span id="modal-target-name"></span>'})|raw }}</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="relations-loading" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">{{ 'search.loading'|trans }}</span>
                    </div>
                    <p class="mt-2">{{ 'search.loading'|trans }}</p>
                </div>
                <div id="relations-content" style="display: none;">
                    <div class="relation-graph-container mb-4">
                        <div id="mermaid-graph" class="mermaid"></div>
                    </div>
                    <div id="relations-list-container">
                        <h6>Linked Records</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Role</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="relations-list-body"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div id="relations-empty" class="alert alert-info" style="display: none;">
                    {{ 'search.no_relations'|trans }}
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <script>
        mermaid.initialize({ startOnLoad: false, theme: 'default', securityLevel: 'loose' });

        document.addEventListener('turbo:load', function() {
            initRelations();
        });

        // Fallback for non-Turbo environments
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof Turbo === 'undefined') {
                initRelations();
            }
        });

        function initRelations() {
            console.log('Initializing ODIS Relations...');
            // Use event delegation on the document to handle dynamic results (Turbo/Pagination)
            $(document).off('click', '.show-relations-btn').on('click', '.show-relations-btn', function() {
                const name = this.getAttribute('data-name');
                const excludeId = this.getAttribute('data-exclude-id');
                console.log('Show relations clicked for:', name, excludeId);
                showRelations(name, excludeId);
            });
        }

        let pendingRelations = null;
        let pendingTargetName = null;

        function showRelations(name, excludeId) {
            console.log('showRelations called for:', name);
            $('#modal-target-name').text(name);
            $('#relations-loading').show();
            $('#relations-content').hide();
            $('#relations-empty').hide();
            
            // Clear previous graph
            const container = document.getElementById('mermaid-graph');
            if (container) container.innerHTML = '';
            
            // Re-initialize modal reference in case it was replaced by Turbo
            const currentModal = $('#relationsModal');
            console.log('Showing modal:', currentModal.length);
            
            // Reset pending data
            pendingRelations = null;
            pendingTargetName = null;

            // Show the modal
            currentModal.modal('show');

            let url = `/search/relations?name=${encodeURIComponent(name)}`;
            if (excludeId) {
                url += `&exclude_id=${encodeURIComponent(excludeId)}`;
            }

            console.log('Fetching relations from:', url);
            fetch(url)
                .then(response => {
                    if (!response.ok) throw new Error('Network response was not ok: ' + response.statusText);
                    return response.json();
                })
                .then(data => {
                    console.log('Relations data received:', data);
                    $('#relations-loading').hide();
                    if (data.relations && data.relations.length > 0) {
                        pendingRelations = data.relations;
                        pendingTargetName = name;
                        
                        // If modal is already shown, render immediately
                        if (currentModal.hasClass('show')) {
                            console.log('Modal already shown, rendering graph now');
                            renderGraph(name, data.relations);
                        } else {
                            console.log('Modal not yet fully shown, graph rendering will happen on shown.bs.modal');
                        }
                        
                        renderList(data.relations);
                        $('#relations-content').show();
                    } else {
                        console.warn('No relations found for:', name);
                        $('#relations-empty').show();
                    }
                })
                .catch(err => {
                    console.error('Error fetching relations:', err);
                    $('#relations-loading').hide();
                    alert('Error fetching relations data: ' + err.message);
                });
        }

        // Use Bootstrap modal events to ensure correct rendering timing
        $(document).on('shown.bs.modal', '#relationsModal', function () {
            console.log('Modal shown event fired');
            if (pendingRelations && pendingTargetName) {
                console.log('Rendering pending relations graph');
                renderGraph(pendingTargetName, pendingRelations);
                // Clear pending to avoid double render if modal is hidden and reshown without new data
                // though we clear on showRelations anyway
            }
        });

        function renderGraph(targetName, relations) {
            const container = document.getElementById('mermaid-graph');
            if (!container) return;
            container.innerHTML = '';
            
            // Limit relations in graph to avoid cluttering
            const displayRelations = relations.slice(0, 15);
            
            // Set min-height to ensure container is not collapsed during render
            container.style.minHeight = '300px';
            
            let graphDefinition = 'graph LR\n';
            // Clean target name for Mermaid
            const safeTarget = targetName.replace(/[^\w\s]/gi, '').trim() || 'Target';
            graphDefinition += `  Target(("${safeTarget}"))\n`;
            graphDefinition += `  style Target fill:#007bff,color:#fff,stroke:#0056b3,stroke-width:2px\n`;

            displayRelations.forEach((rel, index) => {
                const safeRelName = rel.name.replace(/[^\w\s]/gi, ' ').replace(/\s+/g, ' ').substring(0, 30).trim() || 'Node';
                const nodeId = `Node${index}`;
                graphDefinition += `  ${nodeId}["${safeRelName}<br/><small>${rel.type}</small>"]\n`;
                graphDefinition += `  Target -- "${rel.role}" --> ${nodeId}\n`;
                graphDefinition += `  click ${nodeId} "${rel.url}" "Open record"\n`;
            });

            if (relations.length > 15) {
                graphDefinition += `  More["and ${relations.length - 15} more"]\n`;
                graphDefinition += `  Target --- More\n`;
            }

            console.log('Rendering Mermaid graph with definition:', graphDefinition);
            try {
                // Use a unique ID for each render to avoid conflicts
                const renderId = 'mermaid-svg-' + Math.random().toString(36).substr(2, 9);
                
                // Ensure mermaid is initialized before rendering
                if (typeof mermaid !== 'undefined') {
                    // Mermaid 10+ API: mermaid.render(id, text, element)
                    const result = mermaid.render(renderId, graphDefinition, container);

                    // Support Promise-based render (Mermaid 10+)
                    if (result instanceof Promise) {
                        result.then(({ svg, bindFunctions }) => {
                            console.log('Mermaid graph rendered successfully (async)');
                            container.style.minHeight = '';
                            container.innerHTML = svg;
                            if (bindFunctions) bindFunctions(container);
                        }).catch(e => {
                            console.error('Mermaid async rendering failed:', e);
                            container.style.minHeight = '';
                            container.innerHTML = `<p class="text-danger small">Failed to render graph: ${e.message}</p>`;
                        });
                    } else if (typeof result === 'string') {
                        // Legacy synchronous return
                        console.log('Mermaid graph rendered successfully (legacy)');
                        container.style.minHeight = '';
                        container.innerHTML = result;
                    } else if (result && result.svg) {
                        // Modern synchronous return object
                        console.log('Mermaid graph rendered successfully (sync object)');
                        container.style.minHeight = '';
                        container.innerHTML = result.svg;
                        if (result.bindFunctions) result.bindFunctions(container);
                    }
                } else {
                    console.error('Mermaid.js is not loaded');
                    container.innerHTML = '<p class="text-warning small">Graph visualization is unavailable.</p>';
                }
            } catch (e) {
                console.error('Mermaid rendering failed:', e);
                container.innerHTML = `<p class="text-danger small">Failed to render graph: ${e.message}</p>`;
            }
        }

        function renderList(relations) {
            const body = document.getElementById('relations-list-body');
            body.innerHTML = '';
            
            relations.forEach(rel => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${rel.name}</td>
                    <td><span class="badge badge-light border">${rel.type}</span></td>
                    <td><span class="text-capitalize">${rel.role}</span></td>
                    <td><a href="${rel.url}" target="_blank" class="btn btn-xs btn-outline-primary"><i class="fa fa-external-link-alt"></i> View</a></td>
                `;
                body.appendChild(tr);
            });
        }
    </script>
{% endblock %}
