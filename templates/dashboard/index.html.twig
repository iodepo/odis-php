{% extends 'base.html.twig' %}

{% block title %}ODIS Crawler Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
<style>
    .btn-link-hover:hover {
        opacity: 0.9;
        transform: translateY(-2px);
        transition: all 0.2s ease;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2) !important;
    }
</style>
{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-12 mb-4">
            <h1 class="display-4"><i class="fa fa-dashboard mr-3"></i>Crawler Dashboard</h1>
            <p class="lead">Monitoring ODIS metadata extraction and indexing status.</p>
            <div id="crawl-status-indicator" class="d-none">
                <span class="badge badge-warning p-2">
                    <i class="fa fa-spinner fa-spin mr-1"></i> A crawl is currently in progress...
                </span>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        {% if latestStat %}
        <div class="col-md-12">
            <div class="row">
                <div class="col-lg-2 col-md-4 mb-4">
                    <div class="card bg-primary text-white shadow-sm h-100">
                        <div class="card-body text-center px-2">
                            <h6 class="text-uppercase small">Total Nodes</h6>
                            <h2 class="h1" id="stat-nodes">{{ totalNodes }}</h2>
                            <p class="mb-0 small">Discovered</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4 mb-4">
                    <div class="card bg-info text-white shadow-sm h-100">
                        <div class="card-body text-center px-2">
                            <h6 class="text-uppercase small">Pages</h6>
                            <h2 class="h1" id="stat-pages">{{ totalPages }}</h2>
                            <p class="mb-0 small">Visited</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <div class="card bg-success text-white shadow-sm h-100">
                        <div class="card-body text-center px-2">
                            <h6 class="text-uppercase small">Total Valid JSON-LD</h6>
                            <h2 class="h1" id="stat-valid">{{ totalValid }}</h2>
                            <p class="mb-0 small">Total Indexed</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <a href="{{ path('app_download_invalid') }}" class="text-decoration-none h-100">
                        <div class="card bg-danger text-white shadow-sm h-100 btn-link-hover">
                            <div class="card-body text-center px-2">
                                <h6 class="text-uppercase small">Invalid</h6>
                                <h2 class="h1" id="stat-invalid">{{ totalInvalid }}</h2>
                                <p class="mb-0 small">Format</p>
                                <span class="badge badge-light mt-2"><i class="fa fa-download mr-1"></i>Report</span>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <a href="{{ path('app_download_errors') }}" class="text-decoration-none h-100">
                        <div class="card bg-warning text-dark shadow-sm h-100 btn-link-hover">
                            <div class="card-body text-center px-2">
                                <h6 class="text-uppercase small font-weight-bold">Summary Errors</h6>
                                <h2 class="h1" id="stat-errors">{{ totalIssues }}</h2>
                                <p class="mb-0 small">Issues Logged</p>
                                <span class="badge badge-dark mt-2"><i class="fa fa-download mr-1"></i>Report</span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Crawl History (Last 10 Runs)</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Date & Time</th>
                                <th>Duration</th>
                                <th>Nodes</th>
                                <th>Pages</th>
                                <th>Valid</th>
                                <th>Invalid</th>
                                <th>Issues</th>
                                <th>Success Rate</th>
                                <th class="text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody id="history-table-body">
                            {% for stat in history %}
                            <tr>
                                <td>{{ stat.createdAt|date('Y-m-d H:i:s') }}</td>
                                <td>
                                    <span class="badge badge-secondary">{{ stat.duration|default('0s') }}</span>
                                </td>
                                <td>{{ stat.nodesFound }}</td>
                                <td>{{ stat.pagesCrawled }}</td>
                                <td class="text-success font-weight-bold">{{ stat.validJsonLds }}</td>
                                <td class="text-danger">{{ stat.invalidJsonLds }}</td>
                                <td class="text-warning font-weight-bold">{{ stat.errorDetails|length }}</td>
                                <td>
                                    {% set total = stat.validJsonLds + stat.invalidJsonLds %}
                                    {% if total > 0 %}
                                        {{ (stat.validJsonLds / total * 100)|round(1) }}%
                                    {% else %}
                                        0%
                                    {% endif %}
                                </td>
                                <td class="text-right">
                                    {% if stat.errorDetails is not empty or stat.commandLine is not empty %}
                                        <button class="btn btn-sm btn-outline-info" type="button" data-toggle="collapse" data-target="#details-{{ stat.id }}">
                                            <i class="fa fa-info-circle"></i> Info
                                        </button>
                                    {% else %}
                                        <span class="text-muted small">None</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% if stat.errorDetails is not empty or stat.commandLine is not empty %}
                            <tr class="collapse" id="details-{{ stat.id }}">
                                <td colspan="9" class="bg-light">
                                    <div class="p-3">
                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <h6 class="font-weight-bold">Execution Period:</h6>
                                                <div class="small">
                                                    <strong>Started:</strong> {{ stat.createdAt|date('Y-m-d H:i:s') }}<br>
                                                    <strong>Finished:</strong> {% if stat.finishedAt %}{{ stat.finishedAt|date('Y-m-d H:i:s') }}{% else %}<span class="badge badge-warning">Running...</span>{% endif %}<br>
                                                    <strong>Total Duration:</strong> {{ stat.duration|default('0s') }}
                                                </div>
                                            </div>
                                        </div>
                                        {% if stat.commandLine is not empty %}
                                            <h6 class="font-weight-bold">Command Used:</h6>
                                            <div class="bg-dark text-light p-2 rounded mb-3 small">
                                                <code>{{ stat.commandLine }}</code>
                                            </div>
                                        {% endif %}
                                        
                                        {% if stat.errorDetails is not empty %}
                                            <h6 class="font-weight-bold">Error Log:</h6>
                                            <ul class="mb-0 small text-danger">
                                                {% for error in stat.errorDetails %}
                                                    <li>
                                                        {% if error is iterable %}
                                                            {{ error.message|default('Unknown error') }}
                                                        {% else %}
                                                            {{ error }}
                                                        {% endif %}
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            
            <div class="mt-4 text-muted small">
                <p><i class="fa fa-clock-o mr-1"></i> Last update: <span id="last-update-time">{{ latestStat.createdAt|date('Y-m-d H:i:s') }}</span></p>
            </div>

            <div id="processed-section" class="{% if processedEntries is empty %}d-none{% endif %}">
                <div class="card shadow-sm mt-5">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Processed ODISCat Entries</h5>
                        <span id="processed-count" class="badge badge-info">{{ processedEntries|length }} Sources</span>
                    </div>
                    <div class="card-body">
                        <div id="processed-entries-container" class="row">
                            {% for entry in processedEntries %}
                            <div class="col-md-12 col-lg-6 mb-3">
                                <div class="p-3 border rounded bg-light h-100">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="mb-0 text-truncate mr-2" title="{{ entry.name }}">
                                            <span class="badge badge-secondary mr-1">{{ entry.id }}</span> {{ entry.name }}
                                        </h6>
                                        <a href="https://catalogue.odis.org/view/{{ entry.id }}" target="_blank" class="btn btn-sm btn-link p-0 text-primary" title="View in ODISCat">
                                            <i class="fa fa-external-link"></i>
                                        </a>
                                    </div>
                                    <div class="row no-gutters text-center border-top pt-2">
                                        <div class="col-4 border-right">
                                            <div class="small text-muted">Found</div>
                                            <div class="font-weight-bold">{{ entry.recordsFound }}</div>
                                        </div>
                                        <div class="col-4 border-right">
                                            <div class="small text-muted text-success">Valid</div>
                                            <div class="font-weight-bold text-success">{{ entry.validJsonLds }}</div>
                                        </div>
                                        <div class="col-4">
                                            <div class="small text-muted text-danger">Errors</div>
                                            <div class="font-weight-bold text-danger">{{ entry.errorsCount }}</div>
                                        </div>
                                    </div>
                                    {% if entry.errors is not empty %}
                                    <div class="mt-2 pt-2 border-top">
                                        <div class="small font-weight-bold text-muted mb-1">Recent Errors:</div>
                                        <ul class="list-unstyled mb-0 small text-danger">
                                            {% for error in entry.errors %}
                                            <li class="text-truncate" title="{% if error is iterable %}{{ error.message|default('') }}{% else %}{{ error }}{% endif %}">
                                                <i class="fa fa-exclamation-triangle mr-1"></i>
                                                {% if error is iterable %}
                                                    {{ error.message|default('Unknown error') }}
                                                {% else %}
                                                    {{ error }}
                                                {% endif %}
                                            </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-md-12">
            <div class="alert alert-info shadow-sm">
                <h4 class="alert-heading">No statistics available yet!</h4>
                <p>You need to run the crawler at least once to see the data here.</p>
                <hr>
                <p class="mb-0">Run <code>php bin/console app:odis:crawl</code> from your terminal.</p>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function() {
            function updateDashboard() {
                // Capture currently open error collapses
                var openCollapses = [];
                $('.collapse.show').each(function() {
                    openCollapses.push($(this).attr('id'));
                });

                $.getJSON('{{ path('app_api_dashboard_status') }}', function(data) {
                    if (data.latest) {
                        $('#stat-nodes').text(data.totalNodes);
                        $('#stat-pages').text(data.totalPages);
                        $('#stat-valid').text(data.totalValid);
                        $('#stat-invalid').text(data.totalInvalid);
                        $('#stat-errors').text(data.totalIssues);
                        $('#last-update-time').text(data.latest.createdAt);

                        if (data.processedEntries && data.processedEntries.length > 0) {
                            $('#processed-count').text(data.processedEntries.length + ' Sources');
                            var processedHtml = '';
                            data.processedEntries.forEach(function(entry) {
                                processedHtml += '<div class="col-md-12 col-lg-6 mb-3">';
                                processedHtml += '    <div class="p-3 border rounded bg-light h-100">';
                                processedHtml += '        <div class="d-flex justify-content-between align-items-start mb-2">';
                                processedHtml += '            <h6 class="mb-0 text-truncate mr-2" title="' + entry.name + '">';
                                processedHtml += '                <span class="badge badge-secondary mr-1">' + entry.id + '</span> ' + entry.name;
                                processedHtml += '            </h6>';
                                processedHtml += '            <a href="https://catalogue.odis.org/view/' + entry.id + '" target="_blank" class="btn btn-sm btn-link p-0 text-primary" title="View in ODISCat">';
                                processedHtml += '                <i class="fa fa-external-link"></i>';
                                processedHtml += '            </a>';
                                processedHtml += '        </div>';
                                processedHtml += '        <div class="row no-gutters text-center border-top pt-2">';
                                processedHtml += '            <div class="col-4 border-right">';
                                processedHtml += '                <div class="small text-muted">Found</div>';
                                processedHtml += '                <div class="font-weight-bold">' + entry.recordsFound + '</div>';
                                processedHtml += '            </div>';
                                processedHtml += '            <div class="col-4 border-right">';
                                processedHtml += '                <div class="small text-muted text-success">Valid</div>';
                                processedHtml += '                <div class="font-weight-bold text-success">' + entry.validJsonLds + '</div>';
                                processedHtml += '            </div>';
                                processedHtml += '            <div class="col-4">';
                                processedHtml += '                <div class="small text-muted text-danger">Errors</div>';
                                processedHtml += '                <div class="font-weight-bold text-danger">' + entry.errorsCount + '</div>';
                                processedHtml += '            </div>';
                                processedHtml += '        </div>';
                                
                                if (entry.errors && entry.errors.length > 0) {
                                    processedHtml += '        <div class="mt-2 pt-2 border-top">';
                                    processedHtml += '            <div class="small font-weight-bold text-muted mb-1">Recent Errors:</div>';
                                    processedHtml += '            <ul class="list-unstyled mb-0 small text-danger">';
                                    entry.errors.forEach(function(error) {
                                        var message = typeof error === 'object' ? (error.message || 'Unknown error') : error;
                                        processedHtml += '                <li class="text-truncate" title="' + message + '"><i class="fa fa-exclamation-triangle mr-1"></i> ' + message + '</li>';
                                    });
                                    processedHtml += '            </ul>';
                                    processedHtml += '        </div>';
                                }
                                
                                processedHtml += '    </div>';
                                processedHtml += '</div>';
                            });
                            $('#processed-entries-container').html(processedHtml);
                            $('#processed-section').removeClass('d-none');
                        }
                        
                        if (data.latest.status === 'in_progress') {
                            $('#crawl-status-indicator').removeClass('d-none');
                        } else {
                            $('#crawl-status-indicator').addClass('d-none');
                        }
                    }
                    
                    if (data.history && data.history.length > 0) {
                        var html = '';
                        data.history.forEach(function(stat) {
                            var collapseId = 'details-' + stat.id;
                            var isShow = openCollapses.indexOf(collapseId) !== -1 ? ' show' : '';

                            html += '<tr>';
                            html += '<td>' + stat.createdAt + '</td>';
                            html += '<td><span class="badge badge-secondary">' + stat.duration + '</span></td>';
                            html += '<td>' + stat.nodesFound + '</td>';
                            html += '<td>' + stat.pagesCrawled + '</td>';
                            html += '<td class="text-success font-weight-bold">' + stat.validJsonLds + '</td>';
                            html += '<td class="text-danger">' + stat.invalidJsonLds + '</td>';
                            html += '<td class="text-warning font-weight-bold">' + stat.errorDetails.length + '</td>';
                            html += '<td>' + stat.successRate + '</td>';
                            html += '<td class="text-right">';
                            if (stat.hasErrors || stat.commandLine) {
                                html += '<button class="btn btn-sm btn-outline-info" type="button" data-toggle="collapse" data-target="#' + collapseId + '"><i class="fa fa-info-circle"></i> Info</button>';
                            } else {
                                html += '<span class="text-muted small">None</span>';
                            }
                            html += '</td>';
                            html += '</tr>';
                            
                            if (stat.hasErrors || stat.commandLine) {
                                html += '<tr class="collapse' + isShow + '" id="' + collapseId + '">';
                                html += '<td colspan="9" class="bg-light">';
                                html += '<div class="p-3">';

                                html += '<div class="row mb-3">';
                                html += '<div class="col-md-6">';
                                html += '<h6 class="font-weight-bold">Execution Period:</h6>';
                                html += '<div class="small">';
                                html += '<strong>Started:</strong> ' + stat.createdAt + '<br>';
                                html += '<strong>Finished:</strong> ' + (stat.finishedAt ? stat.finishedAt : '<span class="badge badge-warning">Running...</span>') + '<br>';
                                html += '<strong>Total Duration:</strong> ' + stat.duration;
                                html += '</div>';
                                html += '</div>';
                                html += '</div>';
                                
                                if (stat.commandLine) {
                                    html += '<h6 class="font-weight-bold">Command Used:</h6>';
                                    html += '<div class="bg-dark text-light p-2 rounded mb-3 small"><code>' + stat.commandLine + '</code></div>';
                                }

                                if (stat.hasErrors) {
                                    html += '<h6 class="font-weight-bold">Error Log:</h6>';
                                    html += '<ul class="mb-0 small text-danger">';
                                    stat.errorDetails.forEach(function(error) {
                                        var message = typeof error === 'object' ? (error.message || 'Unknown error') : error;
                                        html += '<li>' + message + '</li>';
                                    });
                                    html += '</ul>';
                                }
                                html += '</div>';
                                html += '</td>';
                                html += '</tr>';
                            }
                        });
                        $('#history-table-body').html(html);
                    }
                });
            }
            
            // Poll every 5 seconds
            setInterval(updateDashboard, 5000);
        });
    </script>
{% endblock %}
