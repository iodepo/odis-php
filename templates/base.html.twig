<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css">
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
            <style>
                em {
                    background-color: #fff3cd;
                    font-style: normal;
                    font-weight: bold;
                    padding: 0 2px;
                    border-radius: 2px;
                }
                .result-item:hover {
                    border-color: #007bff;
                }
                .highlight-description em, .highlight-text em {
                    background-color: #ffeeba;
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.3/umd/popper.min.js"></script>
            <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.1.3/js/bootstrap.min.js"></script>
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <i class="fa fa-database mr-2"></i>ODIS Metadata
                </a>
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mr-auto">
                        <li class="nav-item {{ app.request.attributes.get('_route') == 'app_home' ? 'active' }}">
                            <a class="nav-link" href="{{ path('app_home') }}">{{ 'nav.home'|trans }} <i class="fa fa-home"></i></a>
                        </li>
                        <li class="nav-item {{ app.request.attributes.get('_route') == 'app_search' ? 'active' }}">
                            <a class="nav-link" href="{{ path('app_search') }}">{{ 'nav.search'|trans }} <i class="fa fa-search"></i></a>
                        </li>
                        <li class="nav-item {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' }}">
                            <a class="nav-link" href="{{ path('app_dashboard') }}">{{ 'nav.dashboard'|trans }} <i class="fa fa-dashboard"></i></a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ml-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="langDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fa fa-language mr-1"></i>
                                {% set current_lang = app.request.locale %}
                                {% if current_lang == 'en' %}English
                                {% elseif current_lang == 'fr' %}Français
                                {% elseif current_lang == 'es' %}Español
                                {% elseif current_lang == 'zh' %}中文
                                {% elseif current_lang == 'ru' %}Русский
                                {% else %}Language
                                {% endif %}
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow" aria-labelledby="langDropdown">
                                <a class="dropdown-item {{ current_lang == 'en' ? 'active' }}" href="{{ path('change_language', {locale: 'en'}) }}">English</a>
                                <a class="dropdown-item {{ current_lang == 'fr' ? 'active' }}" href="{{ path('change_language', {locale: 'fr'}) }}">Français</a>
                                <a class="dropdown-item {{ current_lang == 'es' ? 'active' }}" href="{{ path('change_language', {locale: 'es'}) }}">Español</a>
                                <a class="dropdown-item {{ current_lang == 'zh' ? 'active' }}" href="{{ path('change_language', {locale: 'zh'}) }}">中文</a>
                                <a class="dropdown-item {{ current_lang == 'ru' ? 'active' }}" href="{{ path('change_language', {locale: 'ru'}) }}">Русский</a>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer class="mt-5 py-4 bg-light text-center border-top">
            <div class="container text-muted small">
                &copy; {{ "now"|date("Y") }} {{ 'footer.copyright'|trans }}
            </div>
        </footer>
    </body>
</html>
