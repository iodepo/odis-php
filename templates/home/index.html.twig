{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }} - Documentation{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="jumbotron shadow-sm">
        <h1 class="display-4">{{ 'home.title'|trans }}</h1>
        <p class="lead">{{ 'home.lead'|trans }}</p>
        <hr class="my-4">
        <p>{{ 'home.built_with'|trans }}</p>
        <a class="btn btn-primary btn-lg" href="{{ path('app_search') }}" role="button">{{ 'home.go_to_search'|trans }}</a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <h2 id="usage">{{ 'home.usage_doc'|trans }}</h2>
            
            <section class="mt-4">
                <h3>{{ 'home.crawling_indexing'|trans }}</h3>
                <p>{{ 'home.crawling_indexing_text'|trans }}</p>
                <div class="card mb-3 border-primary">
                    <div class="card-body bg-light">
                        <h6 class="card-title font-weight-bold">{{ 'home.run_crawler'|trans }}</h6>
                        <div class="mb-2">
                            <span class="text-muted small">{{ 'home.complete_crawl'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl</code>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small">{{ 'home.targeted_crawl'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl 3215 3125</code>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small">{{ 'home.skip_ids'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl --skip 3215,3125</code>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small font-weight-bold text-primary">{{ 'home.parallel_crawl'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl --parallel --concurrency 5</code>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small font-weight-bold text-primary">{{ 'home.testing_limits'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl --limit 10</code>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small font-weight-bold text-danger">{{ 'home.clear_index'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl --clear-index</code>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small font-weight-bold text-danger">{{ 'home.clear_stats'|trans }}</span><br>
                            <code>php bin/console app:odis:clear-stats</code>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small font-weight-bold text-danger">{{ 'home.clear_everything'|trans }}</span><br>
                            <code>php bin/console app:odis:clear-stats --all</code>
                        </div>
                        <div class="mt-2">
                            <span class="text-muted small">{{ 'home.verbose_output'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl -v</code>
                        </div>
                    </div>
                </div>
                <p>{{ 'home.crawler_tasks_text'|trans }}</p>
                <ul>
                    <li>{{ 'home.crawler_task_1'|trans }}</li>
                    <li>{{ 'home.crawler_task_2'|trans }}</li>
                    <li>{{ 'home.crawler_task_3'|trans }}</li>
                    <li>{{ 'home.crawler_task_4'|trans }}</li>
                    <li>{{ 'home.crawler_task_5'|trans }}</li>
                    <li>{{ 'home.crawler_task_6'|trans }}</li>
                    <li>{{ 'home.crawler_task_7'|trans }}</li>
                    <li>{{ 'home.crawler_task_8'|trans }}</li>
                    <li>{{ 'home.crawler_task_9'|trans }}</li>
                    <li>{{ 'home.crawler_task_10'|trans }}</li>
                    <li>{{ 'home.crawler_task_11'|trans }}</li>
                    <li>{{ 'home.crawler_task_12'|trans }}</li>
                </ul>
            </section>

            <section class="mt-5">
                <h3>{{ 'home.searching_monitoring'|trans }}</h3>
                <p>{{ 'home.searching_monitoring_text_1'|trans }}</p>
                <p><a href="{{ path('app_search') }}">{{ 'home.searching_monitoring_text_2'|trans }}</a></p>
                <p>{{ 'home.searching_monitoring_text_3'|trans|replace({'Crawler Dashboard': '<a href="' ~ path('app_dashboard') ~ '">Crawler Dashboard</a>'})|raw }}</p>
            </section>

            <section class="mt-5">
                <h3>{{ 'home.configuration'|trans }}</h3>
                <p>{{ 'home.configuration_text'|trans }}</p>
                <ul>
                    <li><code>ELASTICSEARCH_URL</code>: Usually <code>https://localhost:9200</code>.</li>
                    <li><code>ELASTICSEARCH_USER</code>: <code>odis_metadata</code></li>
                    <li><code>ELASTICSEARCH_PASSWORD</code>: The secure password provided during setup.</li>
                </ul>
            </section>

            <section class="mt-5 mb-5">
                <h3>{{ 'home.resetting_data'|trans }}</h3>
                <p>{{ 'home.resetting_data_text'|trans|replace({'Dashboard': '<a href="' ~ path('app_dashboard') ~ '">Dashboard</a>'})|raw }}</p>
                <div class="card mb-3 border-danger">
                    <div class="card-body bg-light">
                        <div class="mb-3">
                            <h6 class="font-weight-bold text-danger">{{ 'home.clear_everything_title'|trans }}</h6>
                            <span class="text-muted small">{{ 'home.clear_everything_text'|trans }}</span><br>
                            <code>php bin/console app:odis:clear-stats --all</code>
                        </div>
                        <div class="mb-3">
                            <h6 class="font-weight-bold text-danger">{{ 'home.clear_stats_title'|trans }}</h6>
                            <span class="text-muted small">{{ 'home.clear_stats_text'|trans }}</span><br>
                            <code>php bin/console app:odis:clear-stats</code>
                        </div>
                        <div class="mb-3">
                            <h6 class="font-weight-bold text-danger">{{ 'home.clear_index_title'|trans }}</h6>
                            <span class="text-muted small">{{ 'home.clear_index_text'|trans }}</span><br>
                            <code>php bin/console app:odis:crawl --clear-index --limit 1</code>
                        </div>
                        <div class="mb-0">
                            <h6 class="font-weight-bold text-danger">{{ 'home.clear_logs_title'|trans }}</h6>
                            <span class="text-muted small">{{ 'home.clear_logs_text'|trans }}</span><br>
                            <code>rm -f crawl_*.log</code>
                        </div>
                    </div>
                </div>
                <div class="alert alert-warning">
                    <strong>{{ 'home.destructive_warning'|trans|split(':')|first }}:</strong> {{ 'home.destructive_warning'|trans|split(':')|slice(1)|join(':') }}
                </div>
            </section>
        </div>

        <div class="col-md-4">
            <div class="card border-info mb-3">
                <div class="card-header bg-info text-white font-weight-bold">{{ 'home.system_status'|trans }}</div>
                <div class="card-body">
                    <p class="card-text">
                        <strong>{{ 'home.framework'|trans }}:</strong> Symfony 8.0<br>
                        <strong>{{ 'home.storage'|trans }}:</strong> Elasticsearch 9.3<br>
                        <strong>{{ 'home.php_version'|trans }}:</strong> 8.5+
                    </p>
                </div>
            </div>
            
            <div class="card border-secondary mb-3">
                <div class="card-header font-weight-bold">{{ 'home.quick_links'|trans }}</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><a href="https://catalogue.odis.org" target="_blank">ODIS Catalogue <i class="fa fa-external-link small"></i></a></li>
                    <li class="list-group-item"><a href="https://github.com/iodepo/odis-arch" target="_blank">ODIS-Arch GitHub <i class="fa fa-external-link small"></i></a></li>
                    <li class="list-group-item"><a href="https://book.odis.org" target="_blank">ODIS Book <i class="fa fa-external-link small"></i></a></li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
